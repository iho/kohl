# Copy to /etc/kohl/seed.env and chmod 600.
# Used by scripts/systemd/kohl-seed.service

CHAIN=kohl
NODE_NAME=kohl-seed-1

# P2P: listen on all interfaces; advertise the address peers can route to.
LISTEN_ADDR=/ip4/0.0.0.0/tcp/30333
# Examples:
#   PUBLIC_ADDR=/ip4/203.0.113.10/tcp/30333
#   PUBLIC_ADDR=/dns/seed.kohl.network/tcp/30333
PUBLIC_ADDR=/ip4/REPLACE_ME/tcp/30333

RPC_PORT=9944
PROMETHEUS_PORT=9615

# 64 hex chars — same seed scheme as kohl-wallet / --mining-seed
# Leave empty only if you change the unit to drop --mining-seed (relay-only).
MINING_SEED=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
