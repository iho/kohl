# Copy to /etc/kohl/miner.env and chmod 600.

CHAIN=kohl
NODE_NAME=kohl-miner-1

# From the seed operator (multiaddr with /p2p/<PeerId>)
BOOTNODE=/ip4/203.0.113.10/tcp/30333/p2p/12D3KooWReplaceMe

LISTEN_ADDR=/ip4/0.0.0.0/tcp/30333
# If you have a public IP, set it; otherwise omit --public-addr from the unit.
PUBLIC_ADDR=/ip4/REPLACE_MINER_PUBLIC_IP/tcp/30333

RPC_PORT=9944
MINING_SEED=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
